<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Licensing Ledger — Songwriters Tracking Sheets</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@600;700;800&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --case:#182e2b;
  --case-2:#213f3a;
  --case-3:#0f211e;
  --brass:#c68a3d;
  --brass-light:#e8c07f;
  --paper:#eef1ec;
  --ink:#182420;
  --ink-2:#42524b;
  --muted:#70817a;
  --surface:#ffffff;
  --border:#dbe2dc;
  --vu-green:#4d8a58;
  --vu-amber:#d9a13b;
  --vu-red:#b8453a;
  --f-disp:'Big Shoulders Display',sans-serif;
  --f-body:'Inter',system-ui,sans-serif;
  --f-mono:'IBM Plex Mono',monospace;
  --shadow:0 2px 14px rgba(15,33,30,.08);
  --shadow-lg:0 10px 34px rgba(15,33,30,.14);
}
html{font-size:14px}
body{font-family:var(--f-body);background:var(--paper);color:var(--ink);min-height:100vh}

/* ── HEADER ── */
.hdr{
  background:var(--case-3);
  padding:0 32px;height:60px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100;
  border-bottom:1px solid rgba(198,138,61,.25);
}
.hdr-left{display:flex;align-items:center;gap:14px}
.reel-mark{width:30px;height:30px;position:relative;flex-shrink:0}
.reel-mark svg{width:100%;height:100%}
.hdr-word{font-family:var(--f-disp);font-weight:700;font-size:19px;letter-spacing:.5px;color:var(--paper);text-transform:uppercase}
.hdr-word span{color:var(--brass)}
.hdr-divider{width:1px;height:20px;background:rgba(238,241,236,.15)}
.hdr-title{color:rgba(238,241,236,.55);font-size:11.5px;font-weight:500;letter-spacing:.4px;font-family:var(--f-mono)}
.hdr-right{display:flex;align-items:center;gap:10px}
.hdr-btn{
  display:flex;align-items:center;gap:7px;
  padding:8px 15px;border-radius:7px;border:none;
  font-family:var(--f-body);font-size:12px;font-weight:600;
  cursor:pointer;transition:all .15s;
}
.hdr-btn.outline{background:rgba(238,241,236,.07);color:rgba(238,241,236,.8);border:1px solid rgba(238,241,236,.15)}
.hdr-btn.outline:hover{background:rgba(238,241,236,.14)}
.hdr-btn.primary{background:var(--brass);color:var(--case-3)}
.hdr-btn.primary:hover{background:var(--brass-light)}

/* ── UPLOAD ZONE ── */
.upload-zone{
  background:var(--case-2);border-bottom:1px solid rgba(198,138,61,.25);
  padding:14px 32px;display:none;align-items:center;gap:16px;flex-wrap:wrap;
}
.upload-zone.open{display:flex}
.upload-info{font-size:12px;color:rgba(238,241,236,.65);flex:1;line-height:1.6}
.upload-info strong{color:var(--paper);display:block;margin-bottom:2px;font-family:var(--f-mono)}
.file-pick{
  display:inline-flex;align-items:center;gap:7px;
  padding:8px 16px;background:var(--brass);color:var(--case-3);
  border-radius:7px;font-size:12px;font-weight:700;cursor:pointer;
}
.file-pick:hover{background:var(--brass-light)}
#fileIn{display:none}
.up-msg{font-size:11.5px;font-weight:600;padding:6px 12px;border-radius:6px;display:none;font-family:var(--f-mono)}
.up-msg.ok{background:rgba(77,138,88,.18);color:#8fd39c;display:block}
.up-msg.err{background:rgba(184,69,58,.18);color:#f0a99e;display:block}

/* ── HERO ── */
.hero{
  background:
    linear-gradient(180deg, rgba(15,33,30,.2) 0%, transparent 40%),
    radial-gradient(circle at 85% -10%, rgba(198,138,61,.16) 0%, transparent 55%),
    linear-gradient(135deg, var(--case) 0%, var(--case-3) 100%);
  padding:44px 32px 40px;position:relative;overflow:hidden;
}
.hero::before{
  content:'';position:absolute;inset:0;opacity:.5;
  background-image:repeating-linear-gradient(90deg, rgba(238,241,236,.025) 0 1px, transparent 1px 34px);
}
.hero-inner{position:relative;z-index:1;max-width:1240px;margin:0 auto;display:grid;grid-template-columns:1.3fr 1fr;gap:32px;align-items:end}
.hero-eyebrow{
  font-family:var(--f-mono);font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;
  color:var(--brass);margin-bottom:12px;display:flex;align-items:center;gap:8px;
}
.hero-eyebrow::before{content:'';width:20px;height:1px;background:var(--brass)}
.hero-title{font-family:var(--f-disp);font-size:38px;font-weight:800;color:var(--paper);line-height:1.02;margin-bottom:4px;text-transform:uppercase;letter-spacing:.3px;outline:none;border-radius:6px;padding:2px 6px;margin-left:-6px;cursor:text;transition:background .15s}
.hero-title:hover{background:rgba(238,241,236,.06)}
.hero-title:focus{background:rgba(238,241,236,.1);box-shadow:0 0 0 1px rgba(198,138,61,.5)}
.hero-title-hint{font-family:var(--f-mono);font-size:10px;color:rgba(238,241,236,.35);margin-bottom:10px;letter-spacing:.3px}
.hero-sub{font-size:13px;color:rgba(238,241,236,.62);line-height:1.6;margin-bottom:18px;max-width:520px}
.hero-chips{display:flex;flex-wrap:wrap;gap:7px}
.hero-chip{
  display:inline-flex;align-items:center;gap:6px;
  padding:5px 11px;border-radius:999px;
  background:rgba(238,241,236,.08);
  border:1px solid rgba(238,241,236,.14);
  font-size:11px;font-weight:600;color:rgba(238,241,236,.85);
}
.hero-chip.active{background:var(--brass);color:var(--case-3);border-color:var(--brass)}
.hero-chip .dot{width:6px;height:6px;border-radius:50%;background:var(--brass)}
.hero-chip.active .dot{background:var(--case-3)}

/* ── COUNTER (tape counter readout) ── */
.counter-box{
  background:var(--case-3);
  border:1px solid rgba(198,138,61,.3);
  border-radius:10px;
  padding:18px 22px;
  box-shadow:inset 0 2px 10px rgba(0,0,0,.4);
}
.counter-label{font-family:var(--f-mono);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(238,241,236,.45);margin-bottom:8px}
.counter-digits{
  font-family:var(--f-mono);font-weight:600;font-size:40px;color:var(--brass-light);
  text-shadow:0 0 18px rgba(232,192,127,.45);letter-spacing:.5px;line-height:1;
}
.counter-foot{display:flex;justify-content:space-between;margin-top:12px;padding-top:12px;border-top:1px dashed rgba(238,241,236,.15)}
.counter-stat{font-family:var(--f-mono)}
.counter-stat-val{font-size:15px;font-weight:600;color:var(--paper)}
.counter-stat-lbl{font-size:9.5px;color:rgba(238,241,236,.4);letter-spacing:.6px;text-transform:uppercase;margin-top:2px}

/* ── MAIN ── */
.main{max-width:1240px;margin:0 auto;padding:26px 32px 56px}

/* ── KPI GRID ── */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:8px}
.kpi{
  background:var(--surface);border:1px solid var(--border);
  border-radius:14px;padding:18px 18px 16px;
  box-shadow:var(--shadow);
  position:relative;overflow:hidden;
}
.kpi-label{font-family:var(--f-mono);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--muted)}
.kpi-value{font-family:var(--f-disp);font-size:28px;font-weight:700;color:var(--ink);line-height:1;margin-top:8px}
.kpi-sub{font-size:11px;color:var(--muted);margin-top:6px;line-height:1.4}
.kpi-accent{position:absolute;left:0;top:0;bottom:0;width:3px}

/* ── SECTION HEADERS ── */
.section-hdr{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:12px;margin-top:28px}
.section-title{font-family:var(--f-disp);font-size:19px;font-weight:700;color:var(--ink);text-transform:uppercase;letter-spacing:.3px}
.section-sub{font-size:11.5px;color:var(--muted);font-family:var(--f-mono)}

/* ── CARDS ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:14px;box-shadow:var(--shadow);overflow:hidden}
.card-head{padding:16px 20px 12px;border-bottom:1px solid var(--border)}
.card-title{font-size:12.5px;font-weight:700;color:var(--ink);margin-bottom:2px;text-transform:uppercase;letter-spacing:.4px}
.card-sub{font-size:11px;color:var(--muted);line-height:1.5}
.card-body{padding:16px 20px 18px}

.two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}

/* ── VU METER BARS (signature element) ── */
.vu-list{display:flex;flex-direction:column;gap:14px}
.vu-row{display:flex;flex-direction:column;gap:5px}
.vu-row-top{display:flex;justify-content:space-between;align-items:baseline}
.vu-name{font-size:12px;font-weight:600;color:var(--ink-2)}
.vu-val{font-family:var(--f-mono);font-size:12px;font-weight:600;color:var(--ink)}
.vu-track{display:flex;gap:2px;height:14px}
.vu-seg{flex:1;border-radius:2px;background:#e6ebe6;transition:background .3s}
.vu-seg.lit-g{background:var(--vu-green)}
.vu-seg.lit-a{background:var(--vu-amber)}
.vu-seg.lit-r{background:var(--vu-red)}
.vu-other{font-size:11px;color:var(--muted);padding-top:2px;font-family:var(--f-mono)}

/* ── TYPE SPLIT ── */
.type-split{display:flex;gap:10px;margin-bottom:14px}
.type-cell{flex:1;background:var(--paper);border:1px solid var(--border);border-radius:10px;padding:10px 14px}
.type-cell-lbl{font-family:var(--f-mono);font-size:9.5px;text-transform:uppercase;letter-spacing:.8px;color:var(--muted)}
.type-cell-val{font-family:var(--f-disp);font-size:18px;font-weight:700;color:var(--ink);margin-top:3px}
.type-cell-sub{font-size:10.5px;color:var(--muted);font-family:var(--f-mono);margin-top:2px}

/* ── COUNTRY LIST ── */
.country-list{display:flex;flex-direction:column;gap:8px}
.country-row{display:flex;align-items:center;gap:10px}
.country-flag{font-family:var(--f-mono);font-size:11px;font-weight:700;color:var(--ink-2);width:28px;flex-shrink:0}
.country-bar-track{flex:1;height:8px;background:#e6ebe6;border-radius:999px;overflow:hidden}
.country-bar-fill{height:100%;border-radius:999px;background:var(--brass)}
.country-val{font-family:var(--f-mono);font-size:11.5px;font-weight:600;color:var(--ink);width:70px;text-align:right;flex-shrink:0}

/* ── MONTH STRIP ── */
.month-strip{display:flex;gap:10px;overflow-x:auto;padding-bottom:6px}
.month-strip::-webkit-scrollbar{height:6px}
.month-strip::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.month-cell{
  flex:0 0 128px;background:var(--surface);border:1px solid var(--border);border-radius:12px;
  padding:14px 16px;position:relative;overflow:hidden;
}
.month-cell::after{content:'';position:absolute;left:0;bottom:0;height:3px;width:100%;background:var(--brass);opacity:.35}
.month-name{font-family:var(--f-mono);font-size:10.5px;color:var(--muted);letter-spacing:.6px;text-transform:uppercase;margin-bottom:8px}
.month-earn{font-family:var(--f-disp);font-size:22px;font-weight:700;color:var(--ink)}
.month-streams{font-family:var(--f-mono);font-size:11px;color:var(--muted);margin-top:4px}

/* ── FILTER CHIPS ── */
.filter-row{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px}
.filter-chip{
  padding:7px 14px;border-radius:999px;border:1px solid var(--border);
  background:var(--surface);font-size:11.5px;font-weight:600;color:var(--ink-2);
  cursor:pointer;transition:all .15s;font-family:var(--f-body);
}
.filter-chip:hover{border-color:var(--brass)}
.filter-chip.active{background:var(--case-3);color:var(--brass-light);border-color:var(--case-3)}

/* ── LEDGER TABLE ── */
.ledger-table{width:100%;border-collapse:separate;border-spacing:0}
.ledger-table thead th{
  font-family:var(--f-mono);font-size:9.5px;text-transform:uppercase;letter-spacing:.8px;
  color:var(--muted);text-align:left;padding:0 14px 10px;font-weight:600;border-bottom:1px solid var(--border);
}
.ledger-table tbody tr{border-bottom:1px solid var(--border)}
.ledger-table tbody tr:nth-child(odd){background:#f7f9f7}
.ledger-table tbody tr:hover{background:#f0f4ee}
.ledger-table tbody tr:last-child{border-bottom:none}
.ledger-table td{padding:11px 14px;vertical-align:middle}
.lg-rank{font-family:var(--f-mono);font-size:11px;color:var(--muted);width:28px}
.lg-track{font-size:12.5px;font-weight:700;color:var(--ink)}
.lg-meta{font-size:11px;color:var(--muted);margin-top:2px}
.lg-badge{display:inline-block;padding:2px 8px;border-radius:5px;background:var(--paper);font-size:10px;font-weight:600;color:var(--ink-2);border:1px solid var(--border)}
.lg-num{font-family:var(--f-mono);font-size:12.5px;font-weight:600;color:var(--ink);text-align:right}
.lg-earn{font-family:var(--f-mono);font-size:12.5px;font-weight:700;color:var(--vu-green);text-align:right}

.empty-state{padding:40px 20px;text-align:center;color:var(--muted);font-size:12.5px}

/* ── FOOTER ── */
.foot{max-width:1240px;margin:0 auto;padding:0 32px 40px;display:flex;justify-content:space-between;align-items:center}
.foot-note{font-size:11px;color:var(--muted);font-family:var(--f-mono)}

@media(max-width:880px){
  .hero-inner{grid-template-columns:1fr}
  .kpi-grid{grid-template-columns:repeat(2,1fr)}
  .two-col{grid-template-columns:1fr}
  .month-strip{flex-direction:column}
}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-left">
    <div class="reel-mark">
      <svg viewBox="0 0 40 40" fill="none">
        <circle cx="20" cy="20" r="18" stroke="#c68a3d" stroke-width="2"/>
        <circle cx="20" cy="20" r="5" fill="#c68a3d"/>
        <circle cx="20" cy="9" r="2.6" fill="#c68a3d" opacity=".7"/>
        <circle cx="29.5" cy="25.5" r="2.6" fill="#c68a3d" opacity=".7"/>
        <circle cx="10.5" cy="25.5" r="2.6" fill="#c68a3d" opacity=".7"/>
      </svg>
    </div>
    <div class="hdr-word">Licensing<span>Ledger</span></div>
    <div class="hdr-divider"></div>
    <div class="hdr-title" id="hdrPeriod">MAY 2026 REPORT</div>
  </div>
  <div class="hdr-right">
    <a href="../index.html" style="font-family:var(--f-mono);font-size:11px;color:rgba(238,241,236,.5);text-decoration:none;margin-right:4px">&larr; All templates</a>
    <button class="hdr-btn outline" onclick="toggleUpload()">↑ Load report</button>
    <button class="hdr-btn primary" onclick="window.print()">Export PDF</button>
  </div>
</div>

<div class="upload-zone" id="uploadZone">
  <div class="upload-info">
    <strong>Load a new CD Baby / DistroKid royalty export</strong>
    Drop in the raw .txt or .csv download exactly as it comes off the site — Licensing &amp; Royalty Details, Digital Distribution Sales, or CD Baby Sales. Columns are matched by name, so order doesn't matter.
  </div>
  <label class="file-pick">Choose file<input type="file" id="fileIn" accept=".txt,.csv,.tsv" onchange="handleUpload(this)"></label>
  <span class="up-msg" id="upMsg"></span>
</div>

<div class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow" id="heroEyebrow">Licensing &amp; Royalty Details</div>
      <div class="hero-title" id="heroTitle" contenteditable="true" spellcheck="false" title="Click to type your name or artist/label name">Your Name Here</div>
      <div class="hero-title-hint">Click your name above to personalize this statement</div>
      <div class="hero-sub" id="heroSub">Streaming and sync royalties across every artist name, cleaned up from the raw CD Baby export.</div>
      <div class="hero-chips" id="artistChips"></div>
    </div>
    <div class="counter-box">
      <div class="counter-label">Total earned, this report</div>
      <div class="counter-digits" id="counterTotal">$0.00</div>
      <div class="counter-foot">
        <div class="counter-stat"><div class="counter-stat-val" id="counterStreams">0</div><div class="counter-stat-lbl">Streams</div></div>
        <div class="counter-stat"><div class="counter-stat-val" id="counterTracks">0</div><div class="counter-stat-lbl">Tracks paid</div></div>
        <div class="counter-stat"><div class="counter-stat-val" id="counterPlatforms">0</div><div class="counter-stat-lbl">Platforms</div></div>
      </div>
    </div>
  </div>
</div>

<div class="main">

  <div class="kpi-grid">
    <div class="kpi"><div class="kpi-accent" style="background:var(--brass)"></div>
      <div class="kpi-label">Top earning artist</div>
      <div class="kpi-value" id="kpiTopArtist">—</div>
      <div class="kpi-sub" id="kpiTopArtistSub">—</div>
    </div>
    <div class="kpi"><div class="kpi-accent" style="background:var(--vu-green)"></div>
      <div class="kpi-label">Top earning track</div>
      <div class="kpi-value" id="kpiTopTrack">—</div>
      <div class="kpi-sub" id="kpiTopTrackSub">—</div>
    </div>
    <div class="kpi"><div class="kpi-accent" style="background:var(--vu-amber)"></div>
      <div class="kpi-label">Top platform</div>
      <div class="kpi-value" id="kpiTopPlatform">—</div>
      <div class="kpi-sub" id="kpiTopPlatformSub">—</div>
    </div>
    <div class="kpi"><div class="kpi-accent" style="background:var(--case)"></div>
      <div class="kpi-label">Avg. per stream</div>
      <div class="kpi-value" id="kpiAvg">—</div>
      <div class="kpi-sub">Across every platform in this report</div>
    </div>
  </div>

  <div class="section-hdr">
    <div class="section-title">By month</div>
    <div class="section-sub" id="monthRangeSub"></div>
  </div>
  <div class="month-strip" id="monthStrip"></div>

  <div class="section-hdr">
    <div class="section-title">Breakdown</div>
    <div class="section-sub">Share of total royalties</div>
  </div>
  <div class="two-col">
    <div class="card">
      <div class="card-head"><div class="card-title">By artist name</div><div class="card-sub">All five pen names, one ledger</div></div>
      <div class="card-body"><div class="vu-list" id="vuArtist"></div></div>
    </div>
    <div class="card">
      <div class="card-head"><div class="card-title">By platform</div><div class="card-sub">Where the plays are actually coming from</div></div>
      <div class="card-body">
        <div class="type-split" id="typeSplit"></div>
        <div class="vu-list" id="vuPlatform"></div>
      </div>
    </div>
  </div>

  <div class="two-col" id="countrySection" style="display:none">
    <div class="card" style="grid-column:1/-1">
      <div class="card-head"><div class="card-title">Top countries</div><div class="card-sub">Where in the world people are actually listening</div></div>
      <div class="card-body"><div class="country-list" id="countryList"></div></div>
    </div>
  </div>

  <div class="section-hdr">
    <div class="section-title">Track ledger</div>
    <div class="section-sub" id="ledgerCountSub"></div>
  </div>
  <div class="filter-row" id="artistFilterRow"></div>
  <div class="card">
    <table class="ledger-table">
      <thead>
        <tr><th style="width:28px"></th><th>Track</th><th>Platform</th><th style="text-align:right">Streams</th><th style="text-align:right">Earned</th></tr>
      </thead>
      <tbody id="ledgerBody"></tbody>
    </table>
  </div>

</div>

<div class="foot">
  <div class="foot-note" id="footerNote">Generated from a raw royalty export</div>
  <div class="foot-note">Numbers reflect gross royalty payouts before distributor cut, where applicable</div>
