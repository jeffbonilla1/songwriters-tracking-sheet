// ── UPLOAD HANDLER ───────────────────────────────────────────────────
function toggleUpload(){
  document.getElementById('uploadZone').classList.toggle('open');
}

function parseDelimited(text){
  // Autodetect tab vs comma delimiter from the header line
  const firstLine = text.split(/\r\n|\n/)[0] || '';
  const delim = firstLine.includes('\t') ? '\t' : ',';
  const lines = text.split(/\r\n|\n/).filter(l => l.trim().length);
  const header = lines[0].split(delim).map(h => h.replace(/^"|"$/g,'').trim());
  const rows = lines.slice(1).map(line => {
    // simple CSV/TSV split respecting quoted fields
    const cells = [];
    let cur = '', inQ = false;
    for(let i=0;i<line.length;i++){
      const c = line[i];
      if(c === '"'){ inQ = !inQ; continue; }
      if(c === delim && !inQ){ cells.push(cur); cur=''; continue; }
      cur += c;
    }
    cells.push(cur);
    const obj = {};
    header.forEach((h,i) => obj[h] = cells[i] !== undefined ? cells[i].trim() : '');
    return obj;
  });
  return rows;
}

function findCol(header, candidates){
  const lower = header.map(h=>h.toLowerCase());
  for(const c of candidates){
    const idx = lower.indexOf(c.toLowerCase());
    if(idx >= 0) return header[idx];
  }
  return null;
}

function handleUpload(input){
  const file = input.files[0]; if(!file) return;
  const msg = document.getElementById('upMsg');
  msg.className='up-msg'; msg.textContent='Parsing…'; msg.style.display='block';

  const fr = new FileReader();
  fr.onload = e => {
    try {
      const text = e.target.result;
      const rows = parseDelimited(text);
      if(!rows.length || Object.keys(rows[0]).length < 3){
        msg.className='up-msg err';
        msg.textContent='Could not read this file. Make sure it is a raw CD Baby / DistroKid text or CSV export.';
        return;
      }
      const header = Object.keys(rows[0]);
      const colArtist = findCol(header, ['Artist Name','Artist']);
      const colTrack  = findCol(header, ['Track Name','Song Title','Track','Title']);
      const colAlbum  = findCol(header, ['Album Name','Release Title','Album','Album Title']);
      const colPartner= findCol(header, ['Partner Name','Store','Platform','Service']);
      const colType   = findCol(header, ['Transaction Type','Type','Sale Type']);
      const colQty    = findCol(header, ['Quantity','Units','Streams','Qty']);
      const colSub    = findCol(header, ['Subtotal','Earnings','Amount','Royalty','Earnings (USD)']);
      const colDate   = findCol(header, ['Sales Date','Sale Date','Sale Month','Reporting Date','Report Date']);
      const colCountry= findCol(header, ['Delivery Country','Country','Country of Sale']);

      if(!colArtist || !colSub){
        msg.className='up-msg err';
        msg.textContent='Could not find Artist Name or Subtotal columns in this file.';
        return;
      }

      const parsed = rows.map(r => {
        let m = '';
        if(colDate && r[colDate]){
          const dm = String(r[colDate]).match(/(\d{1,2})\/\d{1,2}\/(\d{4})/);
          if(dm) m = dm[1].padStart(2,'0') + '/' + dm[2];
        }
        return {
          a: r[colArtist] || 'Unknown Artist',
          al: colAlbum ? (r[colAlbum]||'') : '',
          t: colTrack ? (r[colTrack]||'Unknown Track') : 'Unknown Track',
          p: colPartner ? (r[colPartner]||'Unknown Platform') : 'Unknown Platform',
          ty: colType ? (r[colType]||'') : '',
          m: m || 'Unknown',
          q: colQty ? (parseInt(r[colQty])||0) : 0,
          s: colSub ? (parseFloat(r[colSub])||0) : 0,
        };
      }).filter(r => r.s !== 0 || r.q !== 0);

      if(!parsed.length){
        msg.className='up-msg err';
        msg.textContent='No valid royalty rows found in this file.';
        return;
      }

      // Country breakdown, if the file has one
      if(colCountry){
        const cAgg = {};
        rows.forEach(r => {
          const c = r[colCountry]; if(!c) return;
          const sub = colSub ? (parseFloat(r[colSub])||0) : 0;
          cAgg[c] = (cAgg[c]||0) + sub;
        });
        COUNTRIES = Object.entries(cAgg).map(([c,s])=>({c,s})).sort((a,b)=>b.s-a.s).slice(0,15);
      } else {
        COUNTRIES = [];
      }

      DATA = parsed;
      ACTIVE_ARTIST = '';
      document.getElementById('heroEyebrow').textContent = file.name.replace(/\.[^.]+$/,'').replace(/[_-]/g,' ');
      render();

      msg.className='up-msg ok';
      msg.textContent = '✓ Loaded ' + parsed.length + ' rows from ' + file.name;
      setTimeout(()=>{ document.getElementById('uploadZone').classList.remove('open'); }, 1800);

    } catch(err){
      msg.className='up-msg err';
      msg.textContent = 'Error: ' + err.message;
    }
  };
  fr.readAsText(file);
}

