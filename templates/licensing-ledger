function esc(s){ return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function fmtMoney(n){
  if(n < 0.01 && n > 0) return '$' + n.toFixed(4);
  return '$' + n.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
}
function fmtInt(n){ return Math.round(n).toLocaleString('en-US'); }
function monthLabel(m){
  const [mm,yy] = m.split('/');
  const names = ['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return names[parseInt(mm,10)] + ' ' + yy;
}

function assignColors(artists){
  artists.forEach((a,i) => { if(!ARTIST_COLORS[a]) ARTIST_COLORS[a] = PALETTE[i % PALETTE.length]; });
}

function vuSegments(pct){
  // 20 segments, colored green -> amber -> red by position, lit up to pct
  const total = 20;
  const lit = Math.max(1, Math.round(pct/100*total));
  let html = '';
  for(let i=0;i<total;i++){
    let cls = '';
    if(i < lit){
      if(i < total*0.6) cls = 'lit-g';
      else if(i < total*0.85) cls = 'lit-a';
      else cls = 'lit-r';
    }
    html += `<div class="vu-seg ${cls}"></div>`;
  }
  return html;
}

